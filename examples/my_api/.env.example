# Example environment file. Copy to `.env` and adjust.
#
# Variables use the APP_ prefix. Nested settings separate levels with a double
# underscore (APP_SERVER__PORT maps to server.port). Real environment variables
# take precedence over values set here.

# Selects config/{env}.toml and the `environment` setting.
APP_ENVIRONMENT=development

# Overrides the application name from the config file.
APP_APP_NAME=My API (local)

# Nested server settings.
APP_SERVER__PORT=8000

# A secret; never commit the real value.
APP_API_KEY=dev-placeholder-key
